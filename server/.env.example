# Server
PORT=3001
DATABASE_PATH=./data/sentiment.db

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Monitoring keywords (pipe-separated ORs)
MONITOR_KEYWORDS=your brand|product name|company name

# Alerts
SLACK_WEBHOOK_URL=

# Optional SMTP for email alerts/digest
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# Behavior
NEGATIVE_THRESHOLD=-0.2
POLL_INTERVAL_MS=45000
ENABLE_MOCK_SOURCE=true
